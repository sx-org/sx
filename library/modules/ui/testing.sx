// compose_for_test (G4): drive a component headless — no host, no GPU,
// no renderer — and assert the emitted tree. One ComposeTest owns one
// Ui + one StateStore (one UiRoot), so state persistence, occurrence
// identity, and sweep semantics are assertable across successive builds.
//
// Panic paths (S2 outside-build, K2a/K2b, type change) print their
// contract message and exit 1 — assertable as expected-exit examples,
// the corpus panic-capture mechanism.
#import "modules/std.sx";
#import "modules/ui/compose.sx";
#import "modules/ui/store.sx";
#import "modules/ui/runtime.sx";
#import "modules/ui/view.sx";
#import "modules/ui/stacks.sx";
#import "modules/ui/modifier.sx";
#import "modules/ui/render.sx";
#import "modules/ui/frame.sx";

ComposeTest :: struct {
    root: UiRoot;

    init :: (root: u64 = 1, gpa: Allocator = context.allocator) -> ComposeTest {
        ComposeTest.{ root = UiRoot.init(.{ value = root }, gpa) }
    }

    // One headless build transaction: begin (store + identity state) →
    // run `body` as the typed-return root in VALUE mode (ui set, no
    // sink — S2) → commit (K2b validation, then sweep). The returned
    // View is the built tree, ready for downcast assertions.
    build :: (self: *ComposeTest, body: Closure() -> View) -> View {
        self.root.begin_build();
        v : View = ---;
        push .{ ui = *self.root.ui, ui_store = *self.root.store } {
            v = body();
        }
        self.root.commit_build();
        v
    }

    // A build whose root emits nothing the test wants back (void body);
    // store/identity semantics still run in full.
    build_void :: (self: *ComposeTest, body: Closure()) {
        self.root.begin_build();
        push .{ ui = *self.root.ui, ui_store = *self.root.store } {
            body();
        }
        self.root.commit_build();
    }

    entry_count :: (self: *ComposeTest) -> i64 #get => self.root.store.entries.len;
}

// --- Tree assertions (downcast-based) ---

// The children of a stack container. The slice borrows the emitted
// tree's backing (the downcast copies the struct shell, not the items);
// its length is the container's live child count.
stack_children :: (v: View) -> []ViewChild {
    if vs := v.(?VStack) {
        s := vs.children.items;
        s.len = vs.children.len;
        return s;
    }
    if hs := v.(?HStack) {
        s := hs.children.items;
        s.len = hs.children.len;
        return s;
    }
    print("panic: stack_children on a non-stack view\n");
    process.exit(1);
    empty : []ViewChild = ---;
    empty.len = 0;
    empty
}

// Unwrap exactly one ModBox level — the modified-place shape (§6.3).
mod_child :: (v: View) -> View {
    if mb := v.(?ModBox) { return mb.child.view; }
    print("panic: mod_child on a view that is not a ModBox\n");
    process.exit(1);
    v
}

// --- Structural scene goldens (I9) ---

// A canonical, line-stable dump of a committed frame: every render
// node with its frame, colors, and depth; clip/opacity markers in
// paint order; then the hit list. Byte-exact by construction — pin it
// as an expected/*.stdout golden and regenerate via -Dupdate-goldens.
dump_snapshot :: (s: *CommittedUiSnapshot) {
    print("snapshot rev {} gen {} nodes {} hits {}\n",
        s.revision, s.generation, s.scene.nodes.len, s.hit_list.len);
    i := 0;
    while i < s.scene.nodes.len {
        n := *s.scene.nodes.items[i];
        f := n.frame;
        if n.type == {
            case .rect: {
                print("rect {} {} {} {} c{},{},{},{} o{} d{}\n",
                    f.origin.x, f.origin.y, f.size.width, f.size.height,
                    n.fill_color.r, n.fill_color.g, n.fill_color.b, n.fill_color.a,
                    n.opacity, n.depth);
            }
            case .rounded_rect: {
                print("rrect {} {} {} {} c{},{},{},{} r{} s{},{},{},{} w{} o{} d{}\n",
                    f.origin.x, f.origin.y, f.size.width, f.size.height,
                    n.fill_color.r, n.fill_color.g, n.fill_color.b, n.fill_color.a,
                    n.corner_radius,
                    n.stroke_color.r, n.stroke_color.g, n.stroke_color.b, n.stroke_color.a,
                    n.stroke_width, n.opacity, n.depth);
            }
            case .text: {
                print("text {} {} {} {} '{}' fs{} c{},{},{},{} o{} d{}\n",
                    f.origin.x, f.origin.y, f.size.width, f.size.height,
                    n.text, n.font_size,
                    n.text_color.r, n.text_color.g, n.text_color.b, n.text_color.a,
                    n.opacity, n.depth);
            }
            case .image: {
                print("img {} {} {} {} t{} d{}\n",
                    f.origin.x, f.origin.y, f.size.width, f.size.height,
                    n.texture_id, n.depth);
            }
            case .clip_push: {
                print("clip+ {} {} {} {}\n", f.origin.x, f.origin.y, f.size.width, f.size.height);
            }
            case .clip_pop: { print("clip-\n"); }
            case .opacity_push: { print("op+ {}\n", n.opacity); }
            case .opacity_pop: { print("op-\n"); }
        }
        i += 1;
    }
    i = 0;
    while i < s.hit_list.len {
        h := *s.hit_list.items[i];
        print("hit {} {} {} {} {}\n", h.id,
            h.frame.origin.x, h.frame.origin.y, h.frame.size.width, h.frame.size.height);
        i += 1;
    }
}
