crc32 :: (data: string, initial: i64 = 0) -> i64 {
    crc := (initial ^ 0xffffffff) & 0xffffffff;
    at := 0;
    while at + 3 < data.len {
        crc = (crc >> 8) ^ CRC32_TABLE[(crc ^ data[at].(i64)) & 0xff];
        crc = (crc >> 8) ^ CRC32_TABLE[(crc ^ data[at + 1].(i64)) & 0xff];
        crc = (crc >> 8) ^ CRC32_TABLE[(crc ^ data[at + 2].(i64)) & 0xff];
        crc = (crc >> 8) ^ CRC32_TABLE[(crc ^ data[at + 3].(i64)) & 0xff];
        at += 4;
    }
    while at < data.len {
        crc = (crc >> 8) ^ CRC32_TABLE[(crc ^ data[at].(i64)) & 0xff];
        at += 1;
    }
    (crc ^ 0xffffffff) & 0xffffffff
}

// -----------------------------------------------------------------------------
// Small byte/bit writers

ByteWriter :: struct {
    bytes: List(u8);
    alloc: Allocator;
    failed: bool;

    init :: (alloc: Allocator) -> ByteWriter {
        writer := ByteWriter.{ bytes = .{}, alloc = alloc, failed = false };
        // Keep the empty state fully canonical. This also makes `take()` on a
        // valid empty stream return `{null, 0}`, which callers may safely pass
        // to their allocator's deallocator.
        writer.bytes.items.ptr = null;
        writer.bytes.items.len = 0;
        writer.bytes.cap = 0;
        writer
    }

    init_storage :: (alloc: Allocator, storage: string) -> ByteWriter {
        writer := ByteWriter.init(alloc);
        if storage.ptr != null and storage.len > 0 {
            writer.bytes.items.ptr = storage.ptr;
            writer.bytes.items.len = 0;
            writer.bytes.cap = storage.len;
        }
        writer
    }

    ensure_capacity :: (self: *ByteWriter, needed: i64) -> bool {
        if self.failed { return false; }
        if needed < 0 { self.failed = true; return false; }
        if self.bytes.cap >= needed { return true; }
        new_cap := if self.bytes.cap == 0 then 4 else self.bytes.cap;
        while new_cap < needed {
            if new_cap > i64.max / 2 { self.failed = true; return false; }
            new_cap *= 2;
        }
        raw := self.alloc.alloc_bytes(new_cap);
        if raw == null { self.failed = true; return false; }
        new_ptr : [*]u8 = xx raw;
        i := 0;
        while i < self.bytes.items.len { new_ptr[i] = self.bytes.items[i]; i += 1; }
        if self.bytes.cap > 0 { self.alloc.dealloc_bytes(self.bytes.items.ptr); }
        self.bytes.items.ptr = new_ptr;
        self.bytes.cap = new_cap;
        true
    }

    put :: (self: *ByteWriter, byte: i64) {
        if !self.ensure_capacity(self.bytes.len + 1) { return; }
        self.bytes.items.ptr[self.bytes.items.len] = (byte & 0xff).(u8);
        self.bytes.items.len += 1;
    }

    put_bytes :: (self: *ByteWriter, data: string) {
        if data.len > i64.max - self.bytes.len or !self.ensure_capacity(self.bytes.len + data.len) { return; }
        i := 0;
        while i < data.len {
            self.bytes.items.ptr[self.bytes.items.len] = data[i];
            self.bytes.items.len += 1;
            i += 1;
        }
    }

    put_u16le :: (self: *ByteWriter, value: i64) {
        self.put(value);
        self.put(value >> 8);
    }

    put_u32le :: (self: *ByteWriter, value: i64) {
        self.put(value);
        self.put(value >> 8);
        self.put(value >> 16);
        self.put(value >> 24);
    }

    put_u64le :: (self: *ByteWriter, value: i64) {
        self.put(value);
        self.put(value >> 8);
        self.put(value >> 16);
        self.put(value >> 24);
        self.put(value >> 32);
        self.put(value >> 40);
        self.put(value >> 48);
        self.put(value >> 56);
    }

    put_u32be :: (self: *ByteWriter, value: i64) {
        self.put(value >> 24);
        self.put(value >> 16);
        self.put(value >> 8);
        self.put(value);
    }

    take :: (self: *ByteWriter) -> string {
        if self.failed {
            self.deinit();
            return .{ ptr = null, len = 0 };
        }
        result := string.{ ptr = self.bytes.items.ptr, len = self.bytes.items.len };
        self.bytes.items.ptr = null;
        self.bytes.items.len = 0;
        self.bytes.cap = 0;
        result
    }

    deinit :: (self: *ByteWriter) {
        self.bytes.deinit(self.alloc);
        self.failed = false;
    }
}

private BitWriter :: struct {
    out: ByteWriter;
    bits: i64;
    count: i64;

    init :: (alloc: Allocator) -> BitWriter {
        BitWriter.{ out = ByteWriter.init(alloc), bits = 0, count = 0 }
    }

    init_capacity :: (alloc: Allocator, capacity: i64) -> BitWriter {
        result := BitWriter.init(alloc);
        result.out.ensure_capacity(capacity);
        result
    }

    init_capacity_storage :: (alloc: Allocator, capacity: i64, storage: string) -> BitWriter {
        result := BitWriter.{ out = ByteWriter.init_storage(alloc, storage), bits = 0, count = 0 };
        result.out.ensure_capacity(capacity);
        result
    }

    write :: (self: *BitWriter, value: i64, nbits: i64) {
        if nbits <= 0 { return; }
        mask := if nbits >= 63 then -1 else (1 << nbits) - 1;
        self.bits = self.bits | ((value & mask) << self.count);
        self.count += nbits;
        while self.count >= 8 {
            self.out.put(self.bits);
            self.bits = self.bits >> 8;
            self.count -= 8;
        }
    }

    // tdefl accumulates one match or up to three consecutive literals before
    // committing the 64-bit bit buffer. Callers must keep each batch below 64
    // bits and reserve eight bytes beyond the maximum logical block size.
    accumulate_fast :: (self: *BitWriter, value: i64, nbits: i64) {
        if nbits <= 0 or self.out.failed { return; }
        mask := if nbits >= 63 then -1 else (1 << nbits) - 1;
        self.bits = self.bits | ((value & mask) << self.count);
        self.count += nbits;
    }

    flush_fast :: (self: *BitWriter) {
        if self.out.failed { return; }
        bytes := self.count >> 3;
        if bytes > 0 {
            words : [*]u64 = xx *self.out.bytes.items.ptr[self.out.bytes.items.len];
            words[0] = self.bits.(u64);
            self.out.bytes.items.len += bytes;
            self.bits = self.bits >> (bytes * 8);
            self.count = self.count & 7;
        }
    }

    align :: (self: *BitWriter) {
        if self.count > 0 {
            self.out.put(self.bits);
            self.bits = 0;
            self.count = 0;
        }
    }

    finish :: (self: *BitWriter) -> string {
        self.align();
        self.out.take()
    }
}

private reverse_bits :: (value: i64, nbits: i64) -> i64 {
    result := 0;
    v := value;
    n := nbits;
    while n > 0 {
        result = (result << 1) | (v & 1);
        v = v >> 1;
        n -= 1;
    }
    result
}

