// Dependency-free DEFLATE, zlib, and gzip implementation.
//
// This module contains the codec machinery behind the concrete std codecs.
// Owned results use the allocator supplied to the call; `*_into` results
// borrow caller-owned storage. The compressed byte stream remains compatible
// with the archived miniz reference, but the API and module boundaries are
// native SX.

#import "modules/std/core.sx";
#import "modules/std/list.sx";
#import "modules/std/compress.sx";

private DeflatePath :: enum { fastest; portable; }

private TDEFL_PROBES : [11]i64 = .[0, 1, 6, 32, 16, 32, 128, 256, 512, 768, 1500];
TDEFL_RAW_BLOCK_LIMIT : i64 = 31745;
private TDEFL_LESS_MEMORY_RAW_BLOCK_LIMIT : i64 = 21839;

private TINFL_FLAG_PARSE_ZLIB_HEADER : i64 = 1;
private TINFL_FLAG_HAS_MORE_INPUT : i64 = 2;
private TINFL_FLAG_USING_NON_WRAPPING_OUTPUT_BUF : i64 = 4;
private TINFL_FLAG_COMPUTE_ADLER32 : i64 = 8;

// miniz's public bound is intentionally conservative.
compress_bound :: (source_len: i64) -> (i64, !Error) {
    if source_len < 0 or source_len > 83848836698679778 { raise error.TooLarge; }
    ratio_bound := 128 + (source_len * 110) / 100;
    block_bound := 128 + source_len + ((source_len / (31 * 1024)) + 1) * 5;
    if ratio_bound > block_bound then ratio_bound else block_bound
}

validate_options :: (options: Options) -> !Error {
    if options.level < 0 or options.level > 10 { raise error.InvalidOptions; }
}

validate_output_limit :: (max_output: i64) -> !Error {
    if max_output < 0 { raise error.InvalidArgument; }
}

// -----------------------------------------------------------------------------
// Checksums

adler32 :: (data: string, initial: i64 = 1) -> i64 {
    // An empty slice is an ordinary zero-byte update, independently of its
    // pointer representation. This keeps the native checksum API composable;
    // the old C null-pointer initializer query is not part of std.zlib.
    // miniz keeps both accumulators in mz_uint32. A 5,552-byte block is
    // specifically small enough to avoid overflow, so widening these to i64
    // only makes the hot dependency chain and modulo operations more costly.
    s1 := (initial & 0xffff).(u32);
    s2 := ((initial >> 16) & 0xffff).(u32);
    remaining := data.len;
    block_len := remaining % 5552;
    at := 0;
    while remaining > 0 {
        end := at + block_len;
        // This is miniz's eight-byte dependency-unrolled checksum loop.
        // Besides matching the upstream fast path, the straight-line updates
        // avoid a branch and index recurrence for every source byte.
        while at + 7 < end {
            s1 += data[at].(u32); s2 += s1;
            s1 += data[at + 1].(u32); s2 += s1;
            s1 += data[at + 2].(u32); s2 += s1;
            s1 += data[at + 3].(u32); s2 += s1;
            s1 += data[at + 4].(u32); s2 += s1;
            s1 += data[at + 5].(u32); s2 += s1;
            s1 += data[at + 6].(u32); s2 += s1;
            s1 += data[at + 7].(u32); s2 += s1;
            at += 8;
        }
        while at < end { s1 += data[at].(u32); s2 += s1; at += 1; }
        s1 = s1 % 65521;
        s2 = s2 % 65521;
        remaining -= block_len;
        block_len = 5552;
    }
    ((s2 << 16) | s1).(i64)
}

