// ── Opaque context blobs (see header) ───────────────────────────────
// ssl_context  448 → 480 (60 slots)
SslContext  :: struct { slots: [60]i64; }
// ssl_config   352 → 384 (48 slots)
SslConfig   :: struct { slots: [48]i64; }
// x509_crt     744 → 776 (97 slots)
X509Crt     :: struct { slots: [97]i64; }
// pk_context    16 →  48 (6 slots)
PkContext   :: struct { slots: [6]i64; }
// ctr_drbg     344 → 376 (47 slots)
CtrDrbg     :: struct { slots: [47]i64; }
// entropy      832 → 864 (108 slots)
Entropy     :: struct { slots: [108]i64; }

// ── SSL context lifecycle + I/O ─────────────────────────────────────
mbedtls_ssl_init         :: (ssl: *SslContext) extern mbedtls;
mbedtls_ssl_free         :: (ssl: *SslContext) extern mbedtls;
mbedtls_ssl_setup        :: (ssl: *SslContext, conf: *SslConfig) -> i32 extern mbedtls;
mbedtls_ssl_handshake    :: (ssl: *SslContext) -> i32 extern mbedtls;
mbedtls_ssl_read         :: (ssl: *SslContext, buf: [*]u8, len: usize) -> i32 extern mbedtls;
mbedtls_ssl_write        :: (ssl: *SslContext, buf: [*]u8, len: usize) -> i32 extern mbedtls;
mbedtls_ssl_close_notify :: (ssl: *SslContext) -> i32 extern mbedtls;

// f_send / f_recv are C-ABI callbacks: int (*)(void *ctx, const uchar *buf, size_t len).
mbedtls_ssl_set_bio :: (
    ssl: *SslContext,
    p_bio: *void,
    f_send: (*void, [*]u8, usize) -> i32 abi(.c),
    f_recv: (*void, [*]u8, usize) -> i32 abi(.c),
    f_recv_timeout: *void,
) extern mbedtls;

// ── SSL config lifecycle ────────────────────────────────────────────
mbedtls_ssl_config_init     :: (conf: *SslConfig) extern mbedtls;
mbedtls_ssl_config_free     :: (conf: *SslConfig) extern mbedtls;
mbedtls_ssl_config_defaults :: (conf: *SslConfig, endpoint: i32, transport: i32, preset: i32) -> i32 extern mbedtls;

// f_rng is a C-ABI callback: int (*)(void *p_rng, uchar *out, size_t len).
mbedtls_ssl_conf_rng :: (
    conf: *SslConfig,
    f_rng: (*void, [*]u8, usize) -> i32 abi(.c),
    p_rng: *void,
) extern mbedtls;

mbedtls_ssl_conf_own_cert :: (conf: *SslConfig, own_cert: *X509Crt, pk_key: *PkContext) -> i32 extern mbedtls;
// NOTE: mbedtls_ssl_conf_min/max_tls_version are `static inline` in ssl.h (they
// assign an opaque config field), so they expose NO linkable symbol and cannot
// be bound here as extern. Pinning a min version needs a small C wrapper.

// The trusted CA chain for verifying the PEER's certificate (server-side:
// client-cert auth; client-side: the server's trust anchor). ca_crl may be
// null (bound as *void — we never build CRLs).
mbedtls_ssl_conf_ca_chain :: (conf: *SslConfig, ca_chain: *X509Crt, ca_crl: *void) extern mbedtls;

// ── ALPN (Q3.4) ─────────────────────────────────────────────────────
// protos: NULL-terminated array of NUL-terminated protocol names, in
// preference order. mbedTLS stores the POINTER — the array and every string
// must outlive the config.
mbedtls_ssl_conf_alpn_protocols :: (conf: *SslConfig, protos: [*][*]u8) -> i32 extern mbedtls;
// The negotiated protocol after the handshake (null = none negotiated).
mbedtls_ssl_get_alpn_protocol :: (ssl: *SslContext) -> [*]u8 extern mbedtls;

// ── SNI (Q3.4) ──────────────────────────────────────────────────────
// f_sni fires during the server handshake with the client's server_name
// (NOT NUL-terminated — name_len bytes). Return 0 to continue (after an
// optional mbedtls_ssl_set_hs_own_cert to switch certs); nonzero aborts
// the handshake with an unrecognized_name alert.
mbedtls_ssl_conf_sni :: (
    conf: *SslConfig,
    f_sni: (*void, *SslContext, [*]u8, usize) -> i32 abi(.c),
    p_sni: *void,
) extern mbedtls;
// Switch the handshake's own cert/key from inside the SNI callback.
mbedtls_ssl_set_hs_own_cert :: (ssl: *SslContext, own_cert: *X509Crt, pk_key: *PkContext) -> i32 extern mbedtls;

// Client-side: the expected server name — drives BOTH the SNI extension and
// certificate hostname verification (mbedTLS 3.6 REQUIRES it when the peer
// cert is verified). NUL-terminated.
mbedtls_ssl_set_hostname :: (ssl: *SslContext, hostname: [*]u8) -> i32 extern mbedtls;

// ── X.509 certificate chain ─────────────────────────────────────────
mbedtls_x509_crt_init  :: (crt: *X509Crt) extern mbedtls;
mbedtls_x509_crt_free  :: (crt: *X509Crt) extern mbedtls;
mbedtls_x509_crt_parse :: (chain: *X509Crt, buf: [*]u8, buflen: usize) -> i32 extern mbedtls;

// ── Private key ─────────────────────────────────────────────────────
mbedtls_pk_init :: (ctx: *PkContext) extern mbedtls;
mbedtls_pk_free :: (ctx: *PkContext) extern mbedtls;
// f_rng / p_rng are the DRBG callback + state (PEM decryption RNG).
mbedtls_pk_parse_key :: (
    ctx: *PkContext,
    key: [*]u8, keylen: usize,
    pwd: *void, pwdlen: usize,
    f_rng: (*void, [*]u8, usize) -> i32 abi(.c),
    p_rng: *void,
) -> i32 extern mbedtls;

// ── RNG: CTR_DRBG + entropy ─────────────────────────────────────────
mbedtls_ctr_drbg_init :: (ctx: *CtrDrbg) extern mbedtls;
mbedtls_ctr_drbg_free :: (ctx: *CtrDrbg) extern mbedtls;
// f_entropy is mbedtls_entropy_func; p_entropy is the *Entropy ctx.
mbedtls_ctr_drbg_seed :: (
    ctx: *CtrDrbg,
    f_entropy: (*void, [*]u8, usize) -> i32 abi(.c),
    p_entropy: *void,
    custom: *void, len: usize,
) -> i32 extern mbedtls;

mbedtls_entropy_init :: (ctx: *Entropy) extern mbedtls;
mbedtls_entropy_free :: (ctx: *Entropy) extern mbedtls;
// The default entropy collector — pass its address as ctr_drbg's f_entropy.
mbedtls_entropy_func :: (data: *void, output: [*]u8, len: usize) -> i32 abi(.c) extern mbedtls;
// The DRBG output function — pass its address (with the *CtrDrbg ctx) to
// mbedtls_ssl_conf_rng as the session RNG. abi(.c): int (*)(void *, uchar *, size_t).
mbedtls_ctr_drbg_random :: (p_rng: *void, output: [*]u8, len: usize) -> i32 abi(.c) extern mbedtls;

// ── TLS verification mode (client/peer-auth) ────────────────────────
// authmode controls whether the peer certificate is verified. The server
// provider leaves it at the preset default; a client (T5 loopback test)
// sets VERIFY_NONE to accept the self-signed fixture cert.
mbedtls_ssl_conf_authmode :: (conf: *SslConfig, authmode: i32) extern mbedtls;

// ── Version ─────────────────────────────────────────────────────────
// Writes the version string (e.g. "3.6.6") into a >=9-byte buffer.
mbedtls_version_get_string :: (buf: [*]u8) extern mbedtls;

// ── Constants (numeric values pinned from mbedtls/ssl.h, v3.6.6) ─────
MBEDTLS_SSL_IS_SERVER         :i32: 1;
MBEDTLS_SSL_IS_CLIENT         :i32: 0;
MBEDTLS_SSL_TRANSPORT_STREAM  :i32: 0;
MBEDTLS_SSL_PRESET_DEFAULT    :i32: 0;
MBEDTLS_SSL_VERIFY_NONE       :i32: 0;
MBEDTLS_SSL_VERIFY_OPTIONAL   :i32: 1;
MBEDTLS_SSL_VERIFY_REQUIRED   :i32: 2;
MBEDTLS_ERR_SSL_WANT_READ          :i32: -0x6900;
MBEDTLS_ERR_SSL_WANT_WRITE         :i32: -0x6880;
MBEDTLS_ERR_SSL_PEER_CLOSE_NOTIFY  :i32: -0x7880;
// TLS 1.3 client: ssl_read's non-fatal "a NewSessionTicket arrived" signal —
// the caller retries the read (mainstream servers send 1-2 immediately after
// the handshake).
MBEDTLS_ERR_SSL_RECEIVED_NEW_SESSION_TICKET :i32: -0x7B00;
