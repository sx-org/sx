// =====================================================================
// vendors/mbedtls — sx bindings over the VENDORED mbedTLS (c/, tag
// v3.6.6, Apache-2.0; see VENDORED.md for provenance + the config trim).
//
// `#import "vendors/mbedtls/mbedtls.sx"` gives any sx program native TLS
// with NO system dependency and NO build flags: the `#import c` unit
// below compiles c/library/*.c (109 files) against the sx-owned trimmed
// config (c/sx_mbedtls_config.h, selected via MBEDTLS_CONFIG_FILE), and
// every `extern mbedtls` decl binds against it — through sx's
// content-addressed object cache (compiled once per machine, like the
// sqlite vendor), linking directly into a `sx build` binary or as a
// priority symbol target under `sx run`. A program that never imports
// this module compiles NONE of it.
//
// CONTEXT STRUCTS — opaque sized blobs (same discipline as std.thread's
// MutexBuf). sx never reads these bytes; mbedTLS owns them. Each is a
// `[N]i64` giving the byte count AND 8-byte alignment (the C structs hold
// pointers / size_t); `.{}` zero-fills. Sizes are the v3.6.6 `sizeof`
// rounded UP to an i64 multiple plus headroom — over-sizing is safe
// (mbedTLS only touches the real prefix), under-sizing corrupts the heap;
// aarch64 == x86_64 (all members are pointer / size_t / fixed buffers).
// Measured sizeof (v3.6.6, sx_mbedtls_config.h): ssl_context 448 ·
// ssl_config 352 · x509_crt 744 · pk_context 16 · ctr_drbg 344 ·
// entropy 832. Re-probe after any mbedTLS bump or config change.
// =====================================================================

#import "modules/std.sx";

mbedtls :: #import c {
    #include "c/include/sx_mbedtls_anchor.h";
    #include "c/library/sx_mbedtls_lib_anchor.h";
    #flags  "-Os";
    #source "c/library/aes.c";
    #source "c/library/aesce.c";
    #source "c/library/aesni.c";
    #source "c/library/aria.c";
    #source "c/library/asn1parse.c";
    #source "c/library/asn1write.c";
    #source "c/library/base64.c";
    #source "c/library/bignum.c";
    #source "c/library/bignum_core.c";
    #source "c/library/bignum_mod.c";
    #source "c/library/bignum_mod_raw.c";
    #source "c/library/block_cipher.c";
    #source "c/library/camellia.c";
    #source "c/library/ccm.c";
    #source "c/library/chacha20.c";
    #source "c/library/chachapoly.c";
    #source "c/library/cipher.c";
    #source "c/library/cipher_wrap.c";
    #source "c/library/cmac.c";
    #source "c/library/constant_time.c";
    #source "c/library/ctr_drbg.c";
    #source "c/library/debug.c";
    #source "c/library/des.c";
    #source "c/library/dhm.c";
    #source "c/library/ecdh.c";
    #source "c/library/ecdsa.c";
    #source "c/library/ecjpake.c";
    #source "c/library/ecp.c";
    #source "c/library/ecp_curves.c";
    #source "c/library/ecp_curves_new.c";
    #source "c/library/entropy.c";
    #source "c/library/entropy_poll.c";
    #source "c/library/error.c";
    #source "c/library/gcm.c";
    #source "c/library/hkdf.c";
    #source "c/library/hmac_drbg.c";
    #source "c/library/lmots.c";
    #source "c/library/lms.c";
    #source "c/library/md.c";
    #source "c/library/md5.c";
    #source "c/library/memory_buffer_alloc.c";
    #source "c/library/mps_reader.c";
    #source "c/library/mps_trace.c";
    #source "c/library/net_sockets.c";
    #source "c/library/nist_kw.c";
    #source "c/library/oid.c";
    #source "c/library/padlock.c";
    #source "c/library/pem.c";
    #source "c/library/pk.c";
    #source "c/library/pk_ecc.c";
    #source "c/library/pk_wrap.c";
    #source "c/library/pkcs12.c";
    #source "c/library/pkcs5.c";
    #source "c/library/pkcs7.c";
    #source "c/library/pkparse.c";
    #source "c/library/pkwrite.c";
    #source "c/library/platform.c";
    #source "c/library/platform_util.c";
    #source "c/library/poly1305.c";
    #source "c/library/psa_crypto.c";
    #source "c/library/psa_crypto_aead.c";
    #source "c/library/psa_crypto_cipher.c";
    #source "c/library/psa_crypto_client.c";
    #source "c/library/psa_crypto_driver_wrappers_no_static.c";
    #source "c/library/psa_crypto_ecp.c";
    #source "c/library/psa_crypto_ffdh.c";
    #source "c/library/psa_crypto_hash.c";
