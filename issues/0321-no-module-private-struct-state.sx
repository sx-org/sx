facade :: #import "0321-no-module-private-struct-state/facade.sx";

main :: () -> i32 {
    wrapped := facade.Wrapper.init(1);
    wrapped.state.value = 2;
    forged : facade.Wrapper = .{ state = .{ value = 3 } };
    if wrapped.get() != 2 { return 1; }
    if forged.get() != 3 { return 2; }
    0
}
