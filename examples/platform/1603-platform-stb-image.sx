#import "modules/std.sx";
stb :: #import "vendors/stb_image/stb_image.sx";

main :: () -> i32 {
    w: i32 = 0;
    h: i32 = 0;
    ch: i32 = 0;
    img := stb.stbi_load("test.png", *w, *h, *ch, 4);
    if xx img != 0 {
        print("loaded {}x{} ({} channels)\n", w, h, ch);
        stb.stbi_image_free(xx img);
    } else {
        print("no image (expected in test)\n");
    }
    0
}
