#import "modules/std.sx";

Point :: struct {
    x, y: i32;
}

Color :: struct {
    r, g, b: i32;
}

main :: () {
    p := Point.{10, 20};
    c := Color.{255, 128, 0};
    pc := *p;
    print("p: {}\n", p);
    print("c: {}\n", c);
    print("n: {}\n", 42);
    print("s: {}\n", "hello");
    print("b: {}\n", true);
    print("&p: {}\n", pc);
    print("&p: {}\n", *p);
}
