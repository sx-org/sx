HiddenStruct :: struct {
    value: i64;
    make :: () -> HiddenStruct { .{ value = 11 } }
}

HiddenAlias :: HiddenStruct;
HiddenUnion :: union { number: i64; byte: u8; }
HiddenError :: error { Bad }
HiddenProtocol :: protocol { read :: (self: *Self) -> i64; }
HiddenGeneric :: struct ($T: Type) { value: T; }
