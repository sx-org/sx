#import "modules/std.sx";
#import "modules/std/compress.sx";

ZipSource :: zip.Source;
ZipSink :: zip.Sink;

// Exact output from miniz 77d0dce8627735138c51770d1799a1ef48f2117d
// for the deterministic archive assembled by make_archive(alloc, ""). This
// pins the complete ZIP bytes, including headers, DEFLATE payload, descriptors,
// central directory, and EOCD—not merely sizes or decoded contents.
