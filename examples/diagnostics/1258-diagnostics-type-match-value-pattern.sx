// A type-category match arm must name a type or a category — a value
// pattern on a `Type` subject is a pointed compile error, never a
// silently dead arm (mirrors the any-subject type switch's refusal).
#import "modules/std.sx";

main :: () {
    t := type_of(5);
    if t == {
        case int: print("int\n");
        case 5:   print("five\n");
    }
}
