// An array constant's elements must be compile-time constants — a call
// (or any runtime expression) in an element slot is diagnosed. `#run`
// is the tool for computed constants.

#import "modules/std.sx";

f :: () -> i64 { 7 }
BAD : [2]i64 : .[1, f()];

main :: () {
    print("{}\n", BAD[0]);
}
