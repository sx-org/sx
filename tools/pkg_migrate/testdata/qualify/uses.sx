// qualify fixture: flat uses of `helper` and `CONSTANT` should become
// qualified; mentions in this comment (helper) and in strings must not.
#import "modules/util.sx";

main :: () {
    x := helper(3);            // call position -> util.helper(3)
    y := x + CONSTANT;         // use position  -> util.CONSTANT
    s := "helper CONSTANT";    // inside a string: untouched
    already := util.helper(4); // already qualified: untouched
    lit := Config.{ helper = 1 }; // field init: SKIP, reported
    print("{} {} {} {}\n", x, y, s, already, lit);
}
