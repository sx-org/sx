// One-shot std.zlib encoding benchmark.
//
// Keep encoding separate from decoding so code-layout changes in one loop do
// not perturb the other measurement. The shell harness compares every output
// byte with the pinned miniz C -O3 oracle.

#import "modules/std.sx";

BENCH_WARMUPS : i64 = 3;
BENCH_SAMPLES : i64 = 15;

mono_ns :: () -> i64 {
    ts : time.Timespec = .{};
    if c.clock_gettime(time.CLOCK_MONOTONIC, @ts) != 0 { return -1; }
    ts.sec * 1000000000 + ts.nsec
}

artifact_path :: (label: string, level: i64) -> [:0]u8 {
    if label[0] == 'r' {
        if level == 1 { return ".sx-tmp/bench-compress/sx-repeat-1.zlib"; }
        if level == 6 { return ".sx-tmp/bench-compress/sx-repeat-6.zlib"; }
        return ".sx-tmp/bench-compress/sx-repeat-9.zlib";
    }
    if level == 1 { return ".sx-tmp/bench-compress/sx-random-1.zlib"; }
    if level == 6 { return ".sx-tmp/bench-compress/sx-random-6.zlib"; }
    ".sx-tmp/bench-compress/sx-random-9.zlib"
}

median_sample :: (samples: *[15]i64) -> i64 {
    i := 1;
    while i < BENCH_SAMPLES {
        value := samples[i];
        j := i;
        while j > 0 and samples[j - 1] > value {
            samples[j] = samples[j - 1];
            j -= 1;
        }
        samples[j] = value;
        i += 1;
    }
    samples[BENCH_SAMPLES / 2]
}

run_case :: (label: string, data: string, level: i64, alloc: Allocator) -> bool {
    options : compress.Options = .{ level = level };
    warmup := 0;
    while warmup < BENCH_WARMUPS {
        value := zlib.encode(data, options, alloc) catch { return false; };
        alloc.dealloc_bytes(value.ptr);
        warmup += 1;
    }

    samples : [15]i64 = ---;
    run := 0;
    while run < BENCH_SAMPLES {
        started := mono_ns();
        if started < 0 { return false; }
        value := zlib.encode(data, options, alloc) catch { return false; };
        finished := mono_ns();
        if finished < started {
            alloc.dealloc_bytes(value.ptr);
            return false;
        }
        samples[run] = finished - started;
        alloc.dealloc_bytes(value.ptr);
        run += 1;
    }
    encode_ns := median_sample(@samples);
    if encode_ns <= 0 { return false; }

    packed := zlib.encode(data, options, alloc) catch { return false; };
    safe_ns := if encode_ns > 0 then encode_ns else 1;
    ratio_permille := if data.len > 0 then packed.len * 1000 / data.len else 0;
    throughput := data.len * 1000000000 / 1024 / safe_ns;
    print("{} level={} input={} packed={} ratio_permille={} encode_ns={} encode_KiB_s={}\n",
        label, level, data.len, packed.len, ratio_permille, encode_ns, throughput);
    ok := fs.write_file(artifact_path(label, level), packed);
    alloc.dealloc_bytes(packed.ptr);
    ok
}

run_corpora :: (data: string, alloc: Allocator) -> bool {
    i := 0;
    while i < data.len {
        data.ptr[i] = ('a' + ((i / 97 + i) % 11)).(u8);
        i += 1;
    }
    if !run_case("repetitive", data, 1, alloc) or
       !run_case("repetitive", data, 6, alloc) or
       !run_case("repetitive", data, 9, alloc) { return false; }

    state := 0x12345678;
    i = 0;
    while i < data.len {
        state = (state ^ (state << 13)) & 0xffffffff;
        state = state ^ (state >> 17);
        state = (state ^ (state << 5)) & 0xffffffff;
        data.ptr[i] = (state & 0xff).(u8);
        i += 1;
    }
    run_case("incompressible", data, 1, alloc) and
    run_case("incompressible", data, 6, alloc) and
    run_case("incompressible", data, 9, alloc)
}

main :: () -> i32 {
    gpa := mem.GPA.init();
    raw := gpa.alloc_bytes(1048576);
    if raw == null { return 1; }
    data := string.{ ptr = xx raw, len = 1048576 };
    ok := run_corpora(data, gpa);
    gpa.dealloc_bytes(raw);
    if !ok or gpa.alloc_count != 0 { return 1; }
    0
}
